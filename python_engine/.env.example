# ==========================================
# CONFIGURAÇÕES DO MOTOR IA / SCRAPING B2B
# ==========================================

# 1. Credenciais Infotravel/Orinter
# Preencha com os dados reais de acesso B2B da sua Agência.
# O motor Playwright (Agente 1) usará isso para varrer o JSF de forma autônoma.
ORINTER_USER=usuario.da.agencia
ORINTER_PASS=senha123secreta # Cuidado ao compartilhar este arquivo

# 2. Credenciais Base (LLM)
OPENAI_API_KEY=sk-xxxx...

# 3. Portas e IPs (Não alterar se estiver rodando o docker-compose padrão)
PYTHON_ENGINE_URL=http://localhost:8000
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0
